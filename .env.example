# BookCabinet environment variables
# Copy this file to .env and fill in the values.

# ─── Database ───────────────────────────────────────
# PostgreSQL connection string (required for drizzle ORM)
DATABASE_URL=postgresql://user:password@localhost:5432/bookcabinet

# SQLite database path (Python side). Defaults to a location inside the repo.
# DATABASE_PATH=/home/admin42/bookcabinet/bookcabinet/data/shelf_data.db

# ─── Server ─────────────────────────────────────────
# HTTP server port (default 5000)
PORT=5000

# Node environment: development | production
NODE_ENV=development

# ─── Paths (so the Node server can locate Python scripts) ──
# Absolute path to the repo root on the target machine.
# If unset, server falls back to the directory that contains the running Node process.
# BOOKCABINET_ROOT=/home/admin42/bookcabinet
# PYTHON_BRIDGE_PATH=/home/admin42/bookcabinet/bookcabinet/bridge.py
# AUTH_DAEMON_PATH=/home/admin42/bookcabinet/bookcabinet/services/auth_shutter_daemon.py

# Python log file path (rotated via RotatingFileHandler).
# LOG_FILE=/home/admin42/bookcabinet/logs/bookcabinet.log

# ─── IRBIS library system ───────────────────────────
# IRBIS TCP host and port (default 172.29.67.70:6666)
# IRBIS_HOST=172.29.67.70
# IRBIS_PORT=6666
# IRBIS_DB=IBIS
# IRBIS_BOOKS_DB=KAT%SERV09%
# IRBIS_READERS_DB=RDR
# IRBIS_MOCK=true
# IRBIS credentials — REQUIRED when IRBIS_MOCK=false.
# Leaving these blank will force the client to fail fast rather than silently
# using a baked-in password. Set them in a private .env that is NOT committed.
# IRBIS_USERNAME=
# IRBIS_PASSWORD=

# ─── Telegram notifications ─────────────────────────
# TELEGRAM_BOT_TOKEN=<token from @BotFather>
# TELEGRAM_CHAT_ID=<chat or group id>

# ─── Hardware ───────────────────────────────────────
# Mock mode (no real GPIO). Accepts 1/true/yes/on.
# ОБЯЗАТЕЛЕН везде, кроме согласованных тестов на RPi.
# ВНИМАНИЕ: скрипты tools/*.py мок-режим не поддерживают —
# на машине с pigpiod они двигают реальное железо.
# MOCK_MODE=true

# ─── RFID readers (serial ports) ────────────────────
# RRU9816_PORT=/dev/ttyUSB0
# IQRFID5102_PORT=/dev/ttyUSB2

# ─── Error tracking (Sentry) ────────────────────────
# Leave blank to disable. When set, both Python (bookcabinet/monitoring/sentry_init.py)
# and Node (server/lib/sentry.ts) will initialise Sentry at process start.
# The @sentry/node package is required on the Node side and sentry-sdk on the
# Python side; both initialisations are no-ops when the SDK is missing.
# SENTRY_DSN=
# BOOKCABINET_ENV=production
